docs/ops/private/

# MCP Proxy Secrets
deployment/onyx/proxy_*_secret.conf
deployment/onyx/openapi.json

# Docker volumes & runtime data
*.log
*.pid

# Runtime log directories (supervisord, celery, onyx, apt, etc.)
logs/

# Editor
.vscode/
.idea/
*.swp
*~
*.bak
*.tmp

# Local agent/tool settings
.codex
.qwen/

# OS
.DS_Store
Thumbs.db

