generated_files/
__pycache__/

# Jupyter
.ipynb_checkpoints/
.env
.env.local

# Raw data artifacts (re-downloadable)
arxiv_results.xml

# Large source PDFs at repo root (store in research/robert/ or external storage)
/*.pdf
.aider*

# Literature PDFs
literature/*.pdf
!research/robert/manuscript/boson-probability-function-moving-system.pdf

# Ignore untracked nested repo files
deployment/deer-flow/
deployment/multica/

# Session cookies — never commit
cookies.txt

# Test files at root
/test_*.py

# Build artifacts
.next/
*.pyc

# DeerFlow user data
.deer-flow/users/
docs/platform/multica/

