# =============================================================================
# DeerFlow Environment Configuration
# Copy to .env and fill in your values.
# =============================================================================

# --- Search APIs -----------------------------------------------------------
# Serper API Key (Google Search) - https://serper.dev
SERPER_API_KEY=your-serper-api-key

# Tavily - primary AI-native search
TAVILY_API_KEY=your-tavily-api-key

# Brave Search - parallel search engine
BRAVE_API_KEY=your-brave-api-key

# Exa AI neural search - high-quality niche results
EXA_API_KEY=your-exa-api-key

# Google Custom Search Engine (optional, for Google Workspace orgs)
GOOGLE_CSE_ID=your-google-cse-id
GOOGLE_API_KEY=your-google-api-key

# SearXNG self-hosted (set base URL of your SearXNG instance)
# SEARXNG_BASE_URL=http://localhost:8080

# Jina AI (web fetch / reader)
JINA_API_KEY=your-jina-api-key

# InfoQuest
INFOQUEST_API_KEY=your-infoquest-api-key

# Firecrawl (optional enhanced crawling)
# FIRECRAWL_API_KEY=your-firecrawl-api-key


# --- LLM Providers ---------------------------------------------------------
# OpenRouter (primary gateway)
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# NVIDIA NIM
# NVIDIA_API_KEY=your-nvidia-api-key
# NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1

# DashScope (Qwen)
# DASHSCOPE_API_KEY=your-dashscope-api-key

# OpenAI direct
# OPENAI_API_KEY=your-openai-api-key

# Anthropic direct
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Gemini direct
# GEMINI_API_KEY=your-gemini-api-key

# DeepSeek direct
# DEEPSEEK_API_KEY=your-deepseek-api-key

# Novita (OpenAI-compatible) - https://novita.ai
# NOVITA_API_KEY=your-novita-api-key

# MiniMax (OpenAI-compatible) - https://platform.minimax.io
# MINIMAX_API_KEY=your-minimax-api-key

# Qwen direct (DashScope)
# QWEN_API_KEY=your-qwen-api-key
# QWEN_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# vLLM (OpenAI-compatible self-hosted)
# VLLM_API_KEY=your-vllm-api-key
# VLLM_API_BASE=http://localhost:8000/v1

# AiSci Onyx LiteLLM proxy
# ONYX_API_KEY=your-onyx-api-key
# ONYX_LITELLM_API_BASE=http://host.docker.internal:4000


# --- Memory & Vector Store -------------------------------------------------
# Chroma local vector store
# CHROMA_HOST=localhost
# CHROMA_PORT=8001
# CHROMA_COLLECTION=deerflow_reports

# Qdrant vector store
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-api-key  # required for Qdrant Cloud
# QDRANT_COLLECTION=deerflow_reports

# Mem0 long-term memory (https://mem0.ai)
# MEM0_API_KEY=your-mem0-api-key

# Zep memory server (self-hosted)
# ZEP_API_URL=http://localhost:8000
# ZEP_API_KEY=your-zep-api-key


# --- Async Task Queue (ARQ + Redis) ----------------------------------------
# Redis for ARQ worker queue and SSE pub/sub buffer
REDIS_URL=redis://localhost:6379/0

# Celery (alternative to ARQ if preferred)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1


# --- Code Execution Sandbox ------------------------------------------------
# e2b cloud sandbox (https://e2b.dev) - safe code execution
# E2B_API_KEY=your-e2b-api-key


# --- Output & Export -------------------------------------------------------
# ElevenLabs TTS for podcast generation
# ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Notion API (push reports to Notion)
# NOTION_API_KEY=your-notion-api-key

# Volcengine TTS (original DeerFlow podcast backend)
# VOLCENGINE_API_KEY=your-volcengine-api-key


# --- Observability ---------------------------------------------------------
# Prometheus metrics (set PROMETHEUS_ENABLED=true to expose /metrics)
# PROMETHEUS_ENABLED=false
# PROMETHEUS_PORT=9090

# OpenTelemetry (optional OTLP exporter)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=deerflow

# LangSmith (LLM call monitoring)
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=your-langsmith-api-key
# LANGSMITH_PROJECT=your-langsmith-project


# --- Integrations ----------------------------------------------------------
# GitHub (MCP server + research tool)
# GITHUB_TOKEN=your-github-token

# Slack
# SLACK_BOT_TOKEN=your-slack-bot-token
# SLACK_APP_TOKEN=your-slack-app-token

# Telegram
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Discord
# DISCORD_BOT_TOKEN=your-discord-bot-token

# Feishu / Lark
# FEISHU_APP_ID=your-feishu-app-id
# FEISHU_APP_SECRET=your-feishu-app-secret

# WeCom
# WECOM_BOT_ID=your-wecom-bot-id
# WECOM_BOT_SECRET=your-wecom-bot-secret

# DingTalk
# DINGTALK_CLIENT_ID=your-dingtalk-client-id
# DINGTALK_CLIENT_SECRET=your-dingtalk-client-secret


# --- Database --------------------------------------------------------------
# Postgres (only needed when config.yaml has database.backend: postgres)
# DATABASE_URL=postgresql://deerflow:password@localhost:5432/deerflow


# --- CORS ------------------------------------------------------------------
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001


# --- Gateway ---------------------------------------------------------------
# Set to "false" to disable Swagger UI, ReDoc, and OpenAPI schema in production
# GATEWAY_ENABLE_DOCS=false

# ── Frontend SSR → Gateway wiring ─────────────────────────────────────────────
# The Next.js server uses these to reach the Gateway during SSR (auth checks,
# /api/* rewrites). They default to localhost values that match `make dev` and
# `make start`, so most local users do not need to set them.
#
# Override only when the Gateway is not on localhost:8001 (e.g. when the
# frontend and gateway run on different hosts, in containers with a service
# alias, or behind a different port). docker-compose already sets these.
# DEER_FLOW_INTERNAL_GATEWAY_BASE_URL=http://localhost:8001
# DEER_FLOW_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:2026
