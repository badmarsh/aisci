config_version: 8
agents:
  - name: physics-validation-director
    type: lead
    capacity: 100
  - name: literature-scout
    type: specialist
    capacity: 80
  - name: formula-checker
    type: specialist
    capacity: 80
  - name: fit-analyst
    type: specialist
    capacity: 80
  - name: referee-writer
    type: specialist
    capacity: 80
  - name: figure-table-builder
    type: specialist
    capacity: 60
  - name: evidence-ledger
    type: operations
    capacity: 80
  - name: coder
    type: operations
    capacity: 100
  - name: data-analyst
    type: operations
    capacity: 100
  - name: knowledge-manager
    type: operations
    capacity: 100
  - name: research-coordinator
    type: assistant
    capacity: 100
  - name: financial-researcher
    type: specialist
    capacity: 80
agents_api:
  enabled: true
langgraph:
  recursion_limit: 100
  thinking_enabled: true
  subagent_enabled: true
  context_management:
    max_turns: 50
    summary_threshold: 5
  memory:
    type: persistent
    storage: ./memory
    max_entries: 10000
models:
  - name: qwen3.5-flash
    display_name: Qwen 3.5 Flash (Onyx)
    use: langchain_openai:ChatOpenAI
    model: qwen3.5-flash
    api_key: $ONYX_API_KEY
    base_url: $ONYX_LITELLM_API_BASE
    max_tokens: 32768
  - name: qwen-flash
    display_name: Qwen Flash (Onyx)
    use: langchain_openai:ChatOpenAI
