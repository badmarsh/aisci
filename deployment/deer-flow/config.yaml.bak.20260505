sandbox:
  use: deerflow.community.aio_sandbox:AioSandboxProvider
  image: enterprise-public-cn-beijing.cr.volces.com/vefaas-public/all-in-one-sandbox:latest
  port: 39120
  replicas: 2
  container_prefix: deer-flow-aio-sandbox
  idle_timeout: 1800
  allow_host_bash: false
  bash_output_max_chars: 20000
  read_file_output_max_chars: 50000
  ls_output_max_chars: 20000
  mounts:
    - host_path: /home/ubuntu/aisci
      container_path: /mnt/host/aisci
      read_only: false
  environment:
    PYTHONUNBUFFERED: "1"
log_level: info
token_usage:
  enabled: true
subagents:
  timeout_seconds: 900
  max_turns: 120
  agents:
    general-purpose:
      timeout_seconds: 1800
      max_turns: 160
    bash:
      timeout_seconds: 300
      max_turns: 80
skill_evolution:
  enabled: true
  moderation_model_name: null
tool_groups:
  - name: web
  - name: file:read
  - name: file:write
  - name: bash
  - name: knowledge
tools:
  - name: web_search
    group: web
    use: deerflow.community.ddg_search.tools:web_search_tool
    max_results: 5
  - name: parallel_search
    group: web
    use: deerflow.community.parallel_search.tools:parallel_search_tool
    max_results: 5
  - name: brave_search
    group: web
    use: deerflow.community.brave_search.tools:brave_search_tool
    max_results: 5
  - name: searxng_search
    group: web
    use: deerflow.community.searxng_search.tools:searxng_search_tool
    max_results: 5
  - name: exa_search
    group: web
    use: deerflow.community.exa_search.tools:exa_search_tool
    max_results: 5
  - name: academic_search
    group: web
    use: deerflow.community.academic_search.tools:academic_search_tool
    max_results: 5
  - name: web_scrape
    group: web
    use: deerflow.community.firecrawl.tools:firecrawl_scrape_tool
  - name: web_crawl
    group: web
    use: deerflow.community.firecrawl.tools:firecrawl_crawl_tool
  - name: web_search_fc
    group: web
    use: deerflow.community.firecrawl.tools:firecrawl_search_tool
    max_results: 5
  - name: web_map
    group: web
    use: deerflow.community.firecrawl.tools:firecrawl_map_tool
  - name: web_extract
    group: web
    use: deerflow.community.firecrawl.tools:firecrawl_extract_tool
  - name: web_interact
    group: web
    use: deerflow.community.firecrawl.tools:firecrawl_interact_tool
  - name: web_fetch
    group: web
    use: deerflow.community.jina_ai.tools:web_fetch_tool
    timeout: 10
  - name: image_search
    group: web
    use: deerflow.community.image_search.tools:image_search_tool
    max_results: 5
  - name: ls
    group: file:read
    use: deerflow.sandbox.tools:ls_tool
  - name: read_file
    group: file:read
    use: deerflow.sandbox.tools:read_file_tool
  - name: glob
    group: file:read
    use: deerflow.sandbox.tools:glob_tool
    max_results: 200
  - name: grep
    group: file:read
    use: deerflow.sandbox.tools:grep_tool
    max_results: 100
  - name: write_file
    group: file:write
    use: deerflow.sandbox.tools:write_file_tool
  - name: str_replace
    group: file:write
    use: deerflow.sandbox.tools:str_replace_tool
  - name: bash
    group: bash
    use: deerflow.sandbox.tools:bash_tool
  - name: onyx_search
    group: knowledge
    use: deerflow.community.onyx.tools:onyx_search_tool
    num_hits: 5
  - name: context7_resolve
    group: knowledge
    use: deerflow.community.context7.tools:context7_resolve_library_tool
  - name: context7_docs
    group: knowledge
    use: deerflow.community.context7.tools:context7_get_library_docs_tool
  - name: read_pdf
    group: file:read
    use: deerflow.community.pdf_reader.tools:pdf_reader_tool
  - name: analyze_file
    group: file:read
    use: deerflow.community.excel_analysis.tools:excel_analyze_tool
  - name: generate_mermaid
    group: file:write
    use: deerflow.community.mermaid_generator.tools:mermaid_generator_tool
  - name: add_citation
    group: knowledge
    use: deerflow.community.citation_manager.tools:citation_add_tool
  - name: generate_citations
    group: knowledge
    use: deerflow.community.citation_manager.tools:citation_generate_tool
  - name: list_citations
    group: knowledge
    use: deerflow.community.citation_manager.tools:citation_list_tool
  # Dexter — AI financial research agent
  - name: dexter_financial_research
    group: knowledge
    use: deerflow.community.dexter.tools:dexter_financial_research_tool
  - name: dexter_market_analysis
    group: knowledge
    use: deerflow.community.dexter.tools:dexter_market_analysis_tool
tool_search:
  enabled: true
uploads:
  pdf_converter: auto
  max_files: 10
  max_file_size: 52428800
  max_total_size: 104857600
  auto_convert_documents: false
skills:
  container_path: /mnt/skills
title:
  enabled: true
  max_words: 6
  max_chars: 60
  model_name: null
summarization:
  enabled: true
  model_name: null
  trigger:
    - type: tokens
      value: 15564
    - type: messages
      value: 50
  keep:
    type: messages
    value: 10
  trim_tokens_to_summarize: 15564
  summary_prompt: null
  preserve_recent_skill_count: 5
  preserve_recent_skill_tokens: 25000
  preserve_recent_skill_tokens_per_skill: 5000
  skill_file_read_tool_names:
    - read_file
    - read
    - view
    - cat
memory:
  enabled: true
  storage_path: memory.json
  debounce_seconds: 30
  model_name: null
  max_facts: 100
  fact_confidence_threshold: 0.7
  injection_enabled: true
  max_injection_tokens: 2000
database:
  backend: sqlite
  sqlite_dir: .deer-flow/data
run_events:
  backend: db
  max_trace_content: 10240
  track_token_usage: true
