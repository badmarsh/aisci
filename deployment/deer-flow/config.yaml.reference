config_version: 6
agents:
- name: litigation-director
  type: lead
  capacity: 100
- name: non-litigation-director
  type: lead
  capacity: 100
- name: civil-lawyer
  type: specialist
  capacity: 50
- name: criminal-lawyer
  type: specialist
  capacity: 50
- name: digits
  type: operations
  capacity: 100
- name: coder
  type: operations
  capacity: 100
- name: commercial-lawyer
  type: specialist
  capacity: 50
- name: legal-assistant
  type: assistant
  capacity: 100
- name: contract-lawyer
  type: specialist
  capacity: 50
- name: compliance-lawyer
  type: specialist
  capacity: 50
- name: m-a-lawyer
  type: specialist
  capacity: 50
- name: legal-researcher
  type: specialist
  capacity: 100
- name: account-manager
  type: operations
  capacity: 50
- name: brand-operations
  type: operations
  capacity: 50
- name: data-analyst
  type: operations
  capacity: 100
- name: knowledge-manager
  type: operations
  capacity: 100

langgraph:
  recursion_limit: 100
  thinking_enabled: true
  subagent_enabled: true
  context_management:
    max_turns: 50
    summary_threshold: 5
  memory:
    type: persistent
    storage: ./memory
    max_entries: 10000

# ============================================================================
# Models Configuration
# ============================================================================
models:
# ── OpenRouter Cloud Models ──────────────────────────────────────────────────
- name: claude-4-7-opus
  display_name: Claude 4.7 Opus (OpenRouter)
  use: langchain_openai:ChatOpenAI
  model: anthropic/claude-4.7-opus
  api_key: $OPENROUTER_API_KEY
  base_url: $OPENROUTER_API_BASE
  max_tokens: 8192
  supports_thinking: true
  supports_vision: true
  when_thinking_enabled:
    extra_body:
      thinking:
        type: enabled
  when_thinking_disabled:
    extra_body:
      thinking:
        type: disabled

- name: gemma-4-31b-it
  display_name: Gemma 4 31B IT (OpenRouter)
  use: langchain_openai:ChatOpenAI
  model: google/gemma-4-31b-it
  api_key: $OPENROUTER_API_KEY
  base_url: $OPENROUTER_API_BASE
  max_tokens: 8192
  supports_vision: true

- name: gpt-4o
  display_name: GPT-4o (OpenRouter)
  use: langchain_openai:ChatOpenAI
  model: openai/gpt-4o
  api_key: $OPENROUTER_API_KEY
  base_url: $OPENROUTER_API_BASE
  max_tokens: 8192
  supports_vision: true

- name: gemini-2-5-pro
  display_name: Gemini 2.5 Pro (OpenRouter)
  use: langchain_openai:ChatOpenAI
  model: google/gemini-2.5-pro
  api_key: $OPENROUTER_API_KEY
  base_url: $OPENROUTER_API_BASE
  max_tokens: 8192
  supports_thinking: true
  supports_vision: true
  when_thinking_enabled:
    extra_body:
      thinking:
        type: enabled
  when_thinking_disabled:
    extra_body:
      thinking:
        type: disabled

- name: glm-5-1
  display_name: GLM 5.1 (OpenRouter)
  use: langchain_openai:ChatOpenAI
  model: z-ai/glm-5.1
  api_key: $OPENROUTER_API_KEY
  base_url: $OPENROUTER_API_BASE
  max_tokens: 8192

- name: minimax-m2-7
  display_name: MiniMax M2.7 (OpenRouter)
  use: langchain_openai:ChatOpenAI
  model: minimax/minimax-m2.7
  api_key: $OPENROUTER_API_KEY
  base_url: $OPENROUTER_API_BASE
  max_tokens: 8192
  temperature: 1.0

- name: deepseek-v3-2
  display_name: DeepSeek V3.2 (OpenRouter)
  use: langchain_openai:ChatOpenAI
  model: deepseek/deepseek-v3.2
  api_key: $OPENROUTER_API_KEY
  base_url: $OPENROUTER_API_BASE
  max_tokens: 8192
  supports_thinking: true
  when_thinking_enabled:
    extra_body:
      enable_thinking: true

- name: llama-3-3-70b-instruct
  display_name: Llama 3.3 70B Instruct (OpenRouter)
  use: langchain_openai:ChatOpenAI
  model: meta-llama/llama-3.3-70b-instruct
  api_key: $OPENROUTER_API_KEY
  base_url: $OPENROUTER_API_BASE
  max_tokens: 8192

# ── NVIDIA NIM Models ────────────────────────────────────────────────────────
- name: nvidia-nemotron-3-super
  display_name: Nemotron 3 Super 120B (NVIDIA)
  use: langchain_openai:ChatOpenAI
  model: nvidia/nemotron-3-super-120b-a12b
  api_key: $NVIDIA_API_KEY
  base_url: $NVIDIA_API_BASE
  max_tokens: 4096

- name: nvidia-ising-calibration
  display_name: Ising Calibration 35B (NVIDIA)
  use: langchain_openai:ChatOpenAI
  model: nvidia/ising-calibration-1-35b-a3b
  api_key: $NVIDIA_API_KEY
  base_url: $NVIDIA_API_BASE
  max_tokens: 4096

- name: nvidia-llama-3-1-405b
  display_name: Llama 3.1 405B Instruct (NVIDIA)
  use: langchain_openai:ChatOpenAI
  model: meta/llama-3.1-405b-instruct
  api_key: $NVIDIA_API_KEY
  base_url: $NVIDIA_API_BASE
  max_tokens: 4096

- name: nvidia-llama-3-3-70b
  display_name: Llama 3.3 70B Instruct (NVIDIA)
  use: langchain_openai:ChatOpenAI
  model: meta/llama-3.3-70b-instruct
  api_key: $NVIDIA_API_KEY
  base_url: $NVIDIA_API_BASE
  max_tokens: 4096

# ── NVIDIA NIM: Kimi (Moonshot) ─────────────────────────────────────────────
- name: nvidia-kimi-k2-5
  display_name: Kimi K2.5 (NVIDIA)
  use: langchain_openai:ChatOpenAI
  model: moonshotai/kimi-k2.5
  api_key: $NVIDIA_API_KEY
  base_url: $NVIDIA_API_BASE
  max_tokens: 4096
  supports_thinking: true
  supports_vision: true

# ── NVIDIA NIM: GLM (Z.AI) ──────────────────────────────────────────────────
- name: nvidia-glm-5-1
  display_name: GLM 5.1 (NVIDIA)
  use: langchain_openai:ChatOpenAI
  model: z-ai/glm-5.1
  api_key: $NVIDIA_API_KEY
  base_url: $NVIDIA_API_BASE
  max_tokens: 4096

- name: nvidia-glm5
  display_name: GLM 5 (NVIDIA)
  use: langchain_openai:ChatOpenAI
  model: z-ai/glm5
  api_key: $NVIDIA_API_KEY
  base_url: $NVIDIA_API_BASE
  max_tokens: 4096
  supports_thinking: true

- name: nvidia-glm4-7
  display_name: GLM 4.7 (NVIDIA)
  use: langchain_openai:ChatOpenAI
  model: z-ai/glm4.7
  api_key: $NVIDIA_API_KEY
  base_url: $NVIDIA_API_BASE
  max_tokens: 4096

# ── NVIDIA NIM: Qwen ────────────────────────────────────────────────────────
- name: nvidia-qwen3-5-122b
  display_name: Qwen 3.5 122B (NVIDIA)
  use: langchain_openai:ChatOpenAI
  model: qwen/qwen3.5-122b-a10b
  api_key: $NVIDIA_API_KEY
  base_url: $NVIDIA_API_BASE
  max_tokens: 4096

- name: nvidia-qwen3-coder-480b
  display_name: Qwen 3 Coder 480B (NVIDIA)
  use: langchain_openai:ChatOpenAI
  model: qwen/qwen3-coder-480b-a35b-instruct
  api_key: $NVIDIA_API_KEY
  base_url: $NVIDIA_API_BASE
  max_tokens: 4096

- name: nvidia-qwen3-next-80b
  display_name: Qwen 3 Next 80B Instruct (NVIDIA)
  use: langchain_openai:ChatOpenAI
  model: qwen/qwen3-next-80b-a3b-instruct
  api_key: $NVIDIA_API_KEY
  base_url: $NVIDIA_API_BASE
  max_tokens: 4096

- name: nvidia-qwen3-next-thinking
  display_name: Qwen 3 Next 80B Thinking (NVIDIA)
  use: langchain_openai:ChatOpenAI
  model: qwen/qwen3-next-80b-a3b-thinking
  api_key: $NVIDIA_API_KEY
  base_url: $NVIDIA_API_BASE
  max_tokens: 4096
  supports_thinking: true

# ── Ollama Local Models (onyx-ollama-1 container) ───────────────────────────
- name: qwen3-vl-local
  display_name: Qwen 3 VL (Ollama)
  use: langchain_ollama:ChatOllama
  model: qwen3-vl
  base_url: http://172.19.0.6:11434
  num_predict: 8192
  temperature: 0.7
  supports_vision: true

- name: deepseek-r1-14b-local
  display_name: DeepSeek R1 14B (Ollama)
  use: langchain_ollama:ChatOllama
  model: deepseek-r1:14b
  base_url: http://172.19.0.6:11434
  num_predict: 8192
  temperature: 0.7
  reasoning: true
  supports_thinking: true

- name: gemma3-27b-local
  display_name: Gemma 3 27B (Ollama)
  use: langchain_ollama:ChatOllama
  model: gemma3:27b
  base_url: http://172.19.0.6:11434
  num_predict: 8192
  temperature: 0.7

- name: mxbai-embed-large-local
  display_name: MXBAI Embed Large (Ollama)
  use: langchain_ollama:ChatOllama
  model: mxbai-embed-large
  base_url: http://172.19.0.6:11434
  num_predict: 4096

- name: nomic-embed-text-local
  display_name: Nomic Embed Text (Ollama)
  use: langchain_ollama:ChatOllama
  model: nomic-embed-text
  base_url: http://172.19.0.6:11434
  num_predict: 4096

# ── Ollama Local Models (downloading) ────────────────────────────────────────
# Uncomment when gemma4:31b finishes downloading:
# - name: gemma4-31b-local
#   display_name: Gemma 4 31B (Ollama)
#   use: langchain_ollama:ChatOllama
#   model: gemma4:31b
#   base_url: http://172.19.0.6:11434
#   num_predict: 8192
#   temperature: 0.7
#   reasoning: true
#   supports_thinking: true
#   supports_vision: true

# ── Uncensored LLM (OpenRouter — minimal filtering) ─────────────────────────
- name: uncensored-llm
  display_name: Hermes 3 70B (Uncensored)
  use: langchain_openai:ChatOpenAI
  model: nousresearch/hermes-3-llama-3.1-70b
  api_key: $OPENROUTER_API_KEY
  base_url: $OPENROUTER_API_BASE
  max_tokens: 8192

sandbox:
  use: deerflow.community.aio_sandbox:AioSandboxProvider
  replicas: 3
  allow_host_bash: false
  bash_output_max_chars: 20000
  read_file_output_max_chars: 50000
  ls_output_max_chars: 20000
  # Alibaba special sandbox image for optimal compatibility
  image: enterprise-public-cn-beijing.cr.volces.com/vefaas-public/all-in-one-sandbox:latest

log_level: info
token_usage:
  enabled: true

subagents:
  timeout_seconds: 900
  max_turns: 120
  agents:
    general-purpose:
      timeout_seconds: 1800
      max_turns: 160
    bash:
      timeout_seconds: 300
      max_turns: 80

skill_evolution:
  enabled: true
  moderation_model_name: null

tool_groups:
- name: web
- name: file:read
- name: file:write
- name: bash
- name: council
- name: rag

tools:
- name: web_search
  group: web
  use: deerflow.community.ddg_search.tools:web_search_tool
  max_results: 5

- name: web_fetch
  group: web
  use: deerflow.community.jina_ai.tools:web_fetch_tool
  timeout: 10

- name: image_search
  group: web
  use: deerflow.community.image_search.tools:image_search_tool
  max_results: 5

- name: ls
  group: file:read
  use: deerflow.sandbox.tools:ls_tool

- name: read_file
  group: file:read
  use: deerflow.sandbox.tools:read_file_tool

- name: glob
  group: file:read
  use: deerflow.sandbox.tools:glob_tool
  max_results: 200

- name: grep
  group: file:read
  use: deerflow.sandbox.tools:grep_tool
  max_results: 100

- name: write_file
  group: file:write
  use: deerflow.sandbox.tools:write_file_tool

- name: str_replace
  group: file:write
  use: deerflow.sandbox.tools:str_replace_tool

- name: bash
  group: bash
  use: deerflow.sandbox.tools:bash_tool

- name: llm_council
  group: council
  use: deerflow.community.llm_council.tools:llm_council_tool

- name: rag_search
  group: rag
  use: deerflow.community.rag.rag_tool:rag_search_tool

- name: rag_manage
  group: rag
  use: deerflow.community.rag.rag_tool:rag_manage_tool

tool_search:
  enabled: true

uploads:
  pdf_converter: auto

skills:
  container_path: /mnt/skills

title:
  enabled: true
  max_words: 6
  max_chars: 60
  model_name: null

summarization:
  enabled: true
  model_name: null
  trigger:
  - type: tokens
    value: 15564
  - type: messages
    value: 50
  keep:
    type: messages
    value: 10
  trim_tokens_to_summarize: 15564
  summary_prompt: null

memory:
  enabled: true
  storage_path: memory.json
  debounce_seconds: 30
  model_name: null
  max_facts: 100
  fact_confidence_threshold: 0.7
  injection_enabled: true
  max_injection_tokens: 2000

checkpointer:
  type: sqlite
  connection_string: checkpoints.db