{
  "mcpServers": {
    "filesystem": {
      "enabled": true,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/app",
        "/app/backend/.deer-flow",
        "/app/skills",
        "/home/ubuntu/aisci"
      ],
      "env": {},
      "url": null,
      "headers": {},
      "oauth": null,
      "description": "Provides filesystem access inside the DeerFlow runtime container"
    },
    "github": {
      "enabled": true,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
      },
      "url": null,
      "headers": {},
      "oauth": null,
      "description": "GitHub MCP server for repository operations"
    },
    "brave-search": {
      "enabled": true,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env": {
        "BRAVE_API_KEY": "$BRAVE_SEARCH_API_KEY"
      },
      "url": null,
      "headers": {},
      "oauth": null,
      "description": "Brave Search API for web search results"
    },
    "puppeteer": {
      "enabled": true,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ],
      "env": {},
      "url": null,
      "headers": {},
      "oauth": null,
      "description": "Browser automation with Puppeteer for web scraping and interaction"
    },
    "sqlite": {
      "enabled": true,
      "type": "stdio",
      "command": "uv",
      "args": [
        "tool",
        "run",
        "mcp-server-sqlite",
        "--db-path",
        "/app/backend/.deer-flow/checkpoints.db"
      ],
      "env": {},
      "url": null,
      "headers": {},
      "oauth": null,
      "description": "SQLite database access for internal LangGraph checkpoints"
    },
    "scite": {
      "enabled": true,
      "type": "http",
      "command": null,
      "args": [],
      "env": {},
      "url": "http://onyx-mcp-proxy:80/scite/",
      "headers": {
        "Authorization": "Bearer $file:/tmp/scite_mcp_access_token"
      },
      "oauth": null,
      "description": "Scite API for literature citation contexts and exact manuscript claim verification"
    },
    "consensus": {
      "enabled": true,
      "type": "http",
      "command": null,
      "args": [],
      "env": {},
      "url": "http://onyx-mcp-proxy:80/consensus/",
      "headers": {
        "Authorization": "Bearer $file:/tmp/consensus_mcp_access_token"
      },
      "oauth": null,
      "description": "Consensus API for academic search and claim grounding"
    },
    "onyx": {
      "enabled": true,
      "type": "sse",
      "command": null,
      "args": [],
      "env": {},
      "url": "http://onyx-mcp-proxy:80/onyx/sse",
      "headers": {},
      "oauth": null,
      "description": "Local Onyx MCP bridge for source-grounded search and chat against the AiSci knowledge base"
    },
    "arxiv": {
      "enabled": true,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@fre4x/arxiv"
      ],
      "env": {},
      "url": null,
      "headers": {},
      "oauth": null,
      "description": "arXiv MCP server for direct paper lookup and metadata fetching"
    },
    "playwright": {
      "enabled": true,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp",
        "--headless",
        "--caps",
        "devtools",
        "--allowed-origins",
        "https://consensus.app;https://clerk.consensus.app;https://mcp.consensus.app;https://api.scite.ai;https://scite.ai"
      ],
      "env": {},
      "description": "Playwright MCP browser automation with DevTools capability for OAuth and token-flow debugging"
    }
  },
  "skills": {
    "multi-language": {
      "enabled": false
    }
  }
}
