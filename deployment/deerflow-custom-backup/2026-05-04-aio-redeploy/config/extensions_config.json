{
  "mcpServers": {
    "filesystem": {
      "enabled": true,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/app",
        "/app/backend/.deer-flow",
        "/app/skills"
      ],
      "env": {},
      "url": null,
      "headers": {},
      "oauth": null,
      "description": "Provides filesystem access inside the DeerFlow runtime container"
    },
    "github": {
      "enabled": true,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_TOKEN"
      },
      "url": null,
      "headers": {},
      "oauth": null,
      "description": "GitHub MCP server for repository operations"
    },
    "brave-search": {
      "enabled": true,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env": {
        "BRAVE_API_KEY": "$BRAVE_SEARCH_API_KEY"
      },
      "url": null,
      "headers": {},
      "oauth": null,
      "description": "Brave Search API for web search results"
    },
    "puppeteer": {
      "enabled": true,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ],
      "env": {},
      "url": null,
      "headers": {},
      "oauth": null,
      "description": "Browser automation with Puppeteer for web scraping and interaction"
    },
    "sqlite": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sqlite",
        "/app/backend/.deer-flow/checkpoints.db"
      ],
      "env": {},
      "url": null,
      "headers": {},
      "oauth": null,
      "description": "SQLite database access for internal LangGraph checkpoints"
    },
    "scite": {
      "enabled": true,
      "type": "sse",
      "command": null,
      "args": [],
      "env": {},
      "url": "http://host.docker.internal:8095/scite/sse",
      "headers": {},
      "oauth": null,
      "description": "Scite API for literature citation contexts and exact manuscript claim verification"
    },
    "consensus": {
      "enabled": true,
      "type": "sse",
      "command": null,
      "args": [],
      "env": {},
      "url": "http://host.docker.internal:8095/consensus/sse",
      "headers": {},
      "oauth": null,
      "description": "Consensus API for academic search and claim grounding"
    },
    "onyx": {
      "enabled": true,
      "type": "sse",
      "command": null,
      "args": [],
      "env": {},
      "url": "http://host.docker.internal:8095/onyx/sse",
      "headers": {},
      "oauth": null,
      "description": "Local Onyx MCP bridge for source-grounded search and chat against the AiSci knowledge base"
    },
    "arxiv": {
      "enabled": false,
      "type": "stdio",
      "command": "uv",
      "args": [
        "x",
        "mcp-server-arxiv"
      ],
      "env": {},
      "url": null,
      "headers": {},
      "oauth": null,
      "description": "arXiv MCP server for direct paper lookup and metadata fetching"
    }
  },
  "skills": {
    "multi-language": {
      "enabled": false
    }
  }
}