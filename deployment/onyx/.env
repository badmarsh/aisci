################################################################################
## SYSTEM AND SERVICE CONFIGURATIONS (Internal)
################################################################################
# Ports
HOST_PORT=3000
HOST_PORT_80=80

# Image Tags
CODE_INTERPRETER_IMAGE_TAG=latest
ONYX_WEB_SERVER_IMAGE=onyxdotapp/onyx-web-server:v3.3.0-beta.0
ONYX_MODEL_SERVER_IMAGE=onyxdotapp/onyx-model-server:v3.3.0-beta.0
