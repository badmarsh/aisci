################################################################################
## SYSTEM AND SERVICE CONFIGURATIONS (Internal)
################################################################################
# Ports
HOST_PORT=3000
HOST_PORT_80=80

# Image Tags
CODE_INTERPRETER_IMAGE_TAG=latest
ONYX_WEB_SERVER_IMAGE=onyxdotapp/onyx-web-server:v4.0.0-beta.0
ONYX_MODEL_SERVER_IMAGE=onyxdotapp/onyx-model-server:v4.0.0-beta.0
UNSTRUCTURED_IMAGE=quay.io/unstructured-io/unstructured-api:latest

# Security
OPENSEARCH_ADMIN_PASSWORD=

# Timeouts
NGINX_PROXY_CONNECT_TIMEOUT=600
NGINX_PROXY_SEND_TIMEOUT=600
NGINX_PROXY_READ_TIMEOUT=600

# Paths and Infrastructure
DOCKER_SOCK_PATH=/var/run/docker.sock
VESPA_SKIP_UPGRADE_CHECK=true
DISABLE_MODEL_SERVER=false

# Pointer to services
POSTGRES_HOST=onyx-db
VESPA_HOST=onyx-vespa
REDIS_HOST=onyx-redis
MODEL_SERVER_HOST=onyx-inference
INDEXING_MODEL_SERVER_HOST=onyx-indexing
INTERNAL_URL=http://onyx-api:8080
OPENAI_BASE_URL=http://onyx-litellm:4001/v1
## Unstructured local API (file parsing — PDF, DOCX, etc.)
UNSTRUCTURED_API_URL=http://onyx-unstructured:8000
# Host debug port — container actually maps 127.0.0.1:8000->8000 (not 9560); this var is informational only
UNSTRUCTURED_HOST_PORT=8000

