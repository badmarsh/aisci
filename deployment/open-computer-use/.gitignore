# infra docker secrets
infra/docker/.env

# Local deploy audit log — contains usernames, timestamps, and git messages
# we don't want public.  Written by build-and-push and rollback.
infra/docker/deployments.log

# ── MCP server (TypeScript package — @coasty/mcp) ──
# node_modules is already covered by the unanchored rule at the top, but
# we list the build/cache outputs explicitly so a tooling change (yarn,
# pnpm, bun) can't accidentally start tracking dist/ files.
mcp/dist/
mcp/coverage/
mcp/.vitest-cache/
mcp/*.tsbuildinfo
mcp/.env
temp/*

# OSWorld showcase artifacts — pushed to the dedicated coasty-ai/coasty-osworld
results/
logs/