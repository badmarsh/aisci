#!/bin/bash

# VNC xstartup file for XFCE desktop
# This file is executed by VNC server when starting

# Ensure proper environment
export XDG_RUNTIME_DIR=/tmp/runtime-desktop
export XDG_CURRENT_DESKTOP=XFCE
export DESKTOP_SESSION=xfce
mkdir -p $XDG_RUNTIME_DIR
chmod 700 $XDG_RUNTIME_DIR

# Set proper locale
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# Start D-Bus daemon if not running
if [ -z "$DBUS_SESSION_BUS_ADDRESS" ]; then
    if which dbus-launch >/dev/null 2>&1; then
        eval $(dbus-launch --sh-syntax)
        export DBUS_SESSION_BUS_ADDRESS
    fi
fi

# Configure display settings
[ -r $HOME/.Xresources ] && xrdb $HOME/.Xresources

# Aggressive screen blanking and power management prevention
# Method 1: xset commands
xset s off 2>/dev/null || true
xset s noblank 2>/dev/null || true
xset s 0 0 2>/dev/null || true
xset -dpms 2>/dev/null || true
xset dpms 0 0 0 2>/dev/null || true

# Method 2: Start keep-alive script in background
if [ -f /opt/keep-screen-alive.sh ]; then
    /opt/keep-screen-alive.sh &
    echo "Started keep-screen-alive service"
fi

# Method 3: Start caffeine if available
if command -v caffeine >/dev/null 2>&1; then
    caffeine &
    echo "Started caffeine"
fi

# Method 4: Disable screensaver via xscreensaver
if command -v xscreensaver-command >/dev/null 2>&1; then
    xscreensaver-command -exit 2>/dev/null || true
fi

# Method 5: Ensure power manager is not running
pkill -f xfce4-power-manager 2>/dev/null || true

# Prevent power manager from starting via environment variable
export XFCE4_POWER_MANAGER_DISABLED=1

# Start XFCE desktop in foreground (not background) to keep the session alive
exec /usr/bin/startxfce4 --disable-wm-check