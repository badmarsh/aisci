{
  "name": "coasty-desktop",
  "version": "5.0.1",
  "description": "Coasty Desktop - AI agent for your local machine",
  "author": "Coasty <founders@coasty.ai>",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:clean": "node -e \"const{execSync}=require('child_process');try{if(process.platform==='win32'){execSync('taskkill /F /IM \\\"Coasty Desktop.exe\\\" /T 2>NUL || exit 0',{stdio:'inherit',shell:true});}else{execSync(\\\"pkill -f 'Coasty Desktop' || true\\\",{stdio:'inherit',shell:'/bin/bash'});}}catch(e){}\" && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "package:win": "electron-vite build && electron-builder --win",
    "package:win:signed": "powershell -ExecutionPolicy Bypass -File ./sign-and-build.ps1",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:mac:signed": "bash ./sign-and-build.sh",
    "package:linux": "electron-vite build && electron-builder --linux",
    "package:linux:portable": "electron-vite build && electron-builder --linux tar.gz",
    "package:linux:docker": "electron-vite build && docker run --rm -e ELECTRON_CACHE=/root/.cache/electron -e ELECTRON_BUILDER_CACHE=/root/.cache/electron-builder -v \"%cd%:/project\" -v \"%USERPROFILE%/.cache/electron:/root/.cache/electron\" -v \"%USERPROFILE%/.cache/electron-builder:/root/.cache/electron-builder\" electronuserland/builder:wine /bin/bash -c \"cd /project && npm install --omit=optional && npx electron-builder --linux\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:headed": "playwright test --config=playwright.config.ts --headed",
    "test:e2e:debug": "playwright test --config=playwright.config.ts --debug",
    "test:e2e:build": "electron-vite build && playwright test --config=playwright.config.ts",
    "test:smoke": "node ./scripts/smoke-packaged.mjs"
  },
  "dependencies": {
    "@nut-tree-fork/libnut": "^4.2.6",
    "puppeteer-core": "^24.2.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@supabase/supabase-js": "^2.49.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.4",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.3.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0",
    "zustand": "^5.0.3"
  }
}
