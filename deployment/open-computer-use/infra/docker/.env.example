# Copy to .env (gitignored) and fill in. The build-and-push scripts
# auto-load this file before validating required env vars.

# --- Required ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_ACCOUNT_ID=
BACKEND_REPO=
FRONTEND_REPO=

# --- Optional ---
# AWS_SESSION_TOKEN=
# IMAGE_TAG=latest
# ECR_HOST=<account>.dkr.ecr.<region>.amazonaws.com

# --- Optional frontend build args ---
# ENCRYPTION_KEY=
# CSRF_SECRET=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE=
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_PROFESSIONAL=
# STRIPE_PRICE_ENTERPRISE=
