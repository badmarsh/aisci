# Copy to tests/post_deploy/.env and fill in.  .env is gitignored.

# ── AWS (boto3 infra checks) ──────────────────────────────────────────
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ECS_CLUSTER= 
PROJECT_NAME= 

# ── HTTP targets ─────────────────────────────────────────────────────
FRONTEND_URL= 
BACKEND_PUBLIC_URL= 

# ── Supabase (real user round-trip tests) ────────────────────────────
SUPABASE_URL= 
SUPABASE_ANON_KEY=

# Dedicated throwaway user — NOT an admin.  Create via Supabase dashboard.
TEST_USER_EMAIL= 
TEST_USER_PASSWORD=

# ── Optional ─────────────────────────────────────────────────────────
# Only set if you want to exercise the internal-key path in test_03
INTERNAL_API_KEY=

# Flip these when deploying staging / intermediate states
EXPECT_HTTPS_443_LISTENER=
EXPECT_SIDECAR_REMOVED=
EXPECT_THREE_SERVICE_SPLIT=

# Observability window
LOG_LOOKBACK_MINUTES=

# Set to 1 in fast CI runs
SKIP_SLOW=
